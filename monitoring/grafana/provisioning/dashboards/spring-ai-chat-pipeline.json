      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Chat Stream Duration (Percentiles)",
      "description": "P50 / P95 / P99 thời gian mỗi stream response (histogram_quantile)",
