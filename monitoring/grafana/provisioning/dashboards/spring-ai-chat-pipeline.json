        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "created/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "destroyed/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 32,
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "🔍 Connection Churn Detection",
      "description": "rate(created) & rate(destroyed). Fixed Pool (min=max=idle) → rate ≈ 0. Nếu rate > 0 liên tục → Connection Churn!",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(lettuce_pool_created_total[1m])",
          "legendFormat": "created/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(lettuce_pool_destroyed_total[1m])",
          "legendFormat": "destroyed/s",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 103,
      "title": "🛡️ Resilience — Circuit Breaker, Fallback, Cache (click to expand)",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": {
                "axisBorderShow": false,
                "axisCenteredZero": false,
                "axisLabel": "calls/s",
                "drawStyle": "line",
                "fillOpacity": 15,
                "gradientMode": "scheme",
                "lineInterpolation": "smooth",
                "lineWidth": 2,
                "pointSize": 5,
                "showPoints": "auto",
                "spanNulls": false,
                "stacking": { "group": "A", "mode": "none" }
              },
              "unit": "short"
            },
            "overrides": [
              {
