        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Batch Insert Duration (Percentiles)",
      "description": "P50 / P95 / P99 thời gian batch insert vào PostgreSQL (histogram_quantile)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.5, sum(rate(redis_batch_insert_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
