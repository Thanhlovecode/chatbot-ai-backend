#!/bin/sh
#
# Git commit-msg hook — Validates Conventional Commits format
# Installed via: git config core.hooksPath .githooks
#
# Valid format: <type>(<scope>): <description>
# Types: feat, fix, refactor, perf, test, ci, docs, chore, security, revert
# Subject line max: 72 characters
#

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
    exit 0
fi

# Allow revert commits generated by git
if echo "$COMMIT_MSG" | grep -qE "^Revert \""; then
    exit 0
fi

# Conventional Commits regex
PATTERN="^(feat|fix|refactor|perf|test|ci|docs|chore|security|revert)(\(.+\))?(!)?: .{1,72}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  ❌ INVALID COMMIT MESSAGE"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "  Your message:  $COMMIT_MSG"
    echo ""
    echo "  Required format:"
    echo "    <type>(<scope>): <description>"
    echo ""
    echo "  Valid types:"
    echo "    feat, fix, refactor, perf, test, ci, docs,"
    echo "    chore, security, revert"
    echo ""
    echo "  Rules:"
    echo "    - Subject line max 72 characters"
    echo "    - Lowercase after colon"
    echo "    - No period at end"
    echo ""
    echo "  Examples:"
    echo "    feat(auth): add JWT refresh token rotation"
    echo "    fix(chat): resolve N+1 query in session loading"
    echo "    chore: bump Spring Boot to 3.4.1"
    echo "    feat!: change API response format"
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
fi

# Check subject line length
SUBJECT_LEN=$(echo "$COMMIT_MSG" | wc -c)
if [ "$SUBJECT_LEN" -gt 73 ]; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  ❌ COMMIT MESSAGE TOO LONG"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "  Subject line is $SUBJECT_LEN characters (max 72)."
    echo "  Please shorten your commit message."
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    exit 1
fi

exit 0
